#!/usr/bin/env sh
GRADLE_VERSION=8.5
GRADLE_HOME="${GRADLE_USER_HOME:-$HOME/.gradle}/wrapper/dists/gradle-${GRADLE_VERSION}-bin"
GRADLE_JAR="$GRADLE_HOME/gradle-${GRADLE_VERSION}-bin.zip"

if [ ! -d "$GRADLE_HOME" ]; then
  mkdir -p "$GRADLE_HOME"
  curl -L "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" -o "$GRADLE_JAR"
  unzip -q "$GRADLE_JAR" -d "$GRADLE_HOME"
fi

exec "$GRADLE_HOME/gradle-${GRADLE_VERSION}/bin/gradle" "$@"
